@startuml

enum Role {
  SUPER_ADMIN
  ADMIN
  RESPONSABLE
  GOUVERNEMENT
}

enum StatutEvaluation {
  EN_COURS
  SOUMISE
  EN_VALIDATION
  VALIDEE
  REJETEE
}

enum StatutReclamation {
  EN_ATTENTE
  EN_TRAITEMENT
  RESOLUE
}

enum Maturite {
  INITIAL
  EN_PROGRESSION
  AVANCE
  EXCELLENT
}

enum Niveau {
  N0
  N1
  N2
  N3
}

class Organisme {
  - id : UUID
  - nom : String
  - type : String
  - secteur : String
  - adresse : String
  - email : String
  - telephone : String
  - siteWeb : String
  - actif : Boolean
  - dateCreation : LocalDateTime
}

class Utilisateur {
  - id : UUID
  - email : String
  - motDePasse : String
  - prenom : String
  - nom : String
  - nomComplet : String
  - role : Role
  - telephone : String
  - actif : Boolean
  - statut : String
  - versionToken : Integer
  - derniereConnexion : LocalDateTime
  - dateCreation : LocalDateTime
}

class Evaluation {
  - id : UUID
  - annee : Integer
  - statut : StatutEvaluation
  - scoreGlobal : Float
  - niveauMaturite : Maturite
  - commentaires : String
  - dateDebut : LocalDateTime
  - dateSoumission : LocalDateTime
  - dateValidation : LocalDateTime
}

class Principe {
  - id : UUID
  - numero : Integer
  - nomFr : String
  - nomAr : String
  - nomEn : String
  - descriptionFr : String
  - descriptionAr : String
  - descriptionEn : String
  - poids : Float
  - fixe : Boolean
  - ordre : Integer
}

class BonnePratique {
  - id : UUID
  - numero : Integer
  - libelleFr : String
  - libelleAr : String
  - libelleEn : String
}

class Critere {
  - id : UUID
  - numero : Integer
  - libelleFr : String
  - libelleAr : String
  - libelleEn : String
  - preuvesFr : String
  - preuvesAr : String
  - preuvesEn : String
  - referencesFr : String
  - referencesAr : String
  - referencesEn : String
}

class Reponse {
  - id : UUID
  - niveau : Niveau
  - commentaire : String
  - fichiersPreuve : List<String>
  - liensPreuve : List<String>
  - statut : String
  - commentaireValidateur : String
  - motifRejet : String
  - correctionEffectuee : Boolean
  - dateSoumission : LocalDateTime
}

class ScorePrincipe {
  - id : UUID
  - score : Float
  - noteMaximale : Float
  - poids : Float
}

class ScoreGlobal {
  - id : UUID
  - annee : Integer
  - score : Float
  - niveauMaturite : Maturite
  - classement : Integer
}

class Notification {
  - id : UUID
  - type : String
  - titreFr : String
  - titreAr : String
  - titreEn : String
  - messageFr : String
  - messageAr : String
  - messageEn : String
  - lien : String
  - lu : Boolean
  - dateEnvoi : LocalDateTime
}

class JournalAudit {
  - id : UUID
  - action : String
  - entite : String
  - ancienneValeur : String
  - nouvelleValeur : String
  - adresseIP : String
  - dateAction : LocalDateTime
}

class Reclamation {
  - id : UUID
  - sujet : String
  - message : String
  - statut : StatutReclamation
  - reponseAdmin : String
  - dateCreation : LocalDateTime
  - dateTraitement : LocalDateTime
  - dateResolution : LocalDateTime
}

class DemandeCompte {
  - id : UUID
  - nomEntreprise : String
  - type : String
  - prenomResponsable : String
  - nomResponsable : String
  - emailEntreprise : String
  - telephone : String
  - adresse : String
  - secteur : String
  - message : String
  - fichiersVerification : List<String>
  - statut : String
  - commentaireAdmin : String
  - dateDemande : LocalDateTime
}

class JetonActivation {
  - id : UUID
  - jetonHash : String
  - dateExpiration : LocalDateTime
  - dateUtilisation : LocalDateTime
}

class EmailJob {
  - id : UUID
  - type : String
  - statut : String
  - emailDestinataire : String
  - sujet : String
  - corps : String
  - tentatives : Integer
  - tentativesMax : Integer
  - derniereErreur : String
}

class AuthController
class UtilisateurController
class EvaluationController
class ReponseController
class NotificationController
class DashboardController
class ReclamationController
class AuditLogController
class DemandeCompteController

class AuthService
class UtilisateurService
class EvaluationService
class ReponseService
class NotificationService
class DashboardService
class ReclamationService
class AuditLogService
class DemandeCompteService

' --- Relations Entites ---
Organisme "1" -- "0..*" Utilisateur : responsables
Organisme "1" -- "0..*" Evaluation
Organisme "1" -- "0..*" Reclamation
Organisme "1" -- "0..*" ScoreGlobal
Utilisateur "1" -- "0..*" Notification
Utilisateur "1" -- "0..*" JournalAudit
Utilisateur "1" -- "0..*" Reclamation
Utilisateur "1" -- "0..*" JetonActivation
Utilisateur "1" -- "0..*" EmailJob
Evaluation "1" -- "0..*" Reponse
Evaluation "1" -- "0..*" ScorePrincipe
Evaluation "1" -- "0..*" JournalAudit
Principe "1" -- "1..*" BonnePratique
BonnePratique "1" -- "1..*" Critere
Critere "1" -- "0..*" Reponse
Principe "1" -- "0..*" ScorePrincipe
JetonActivation "1" -- "0..*" EmailJob

' --- Dependances Controleurs -> Services ---
AuthController --> AuthService
AuthController --> UtilisateurService
UtilisateurController --> UtilisateurService
EvaluationController --> EvaluationService
ReponseController --> ReponseService
NotificationController --> NotificationService
DashboardController --> DashboardService
ReclamationController --> ReclamationService
AuditLogController --> AuditLogService
DemandeCompteController --> DemandeCompteService

' --- Dependances Services -> Entites ---
UtilisateurService --> Utilisateur
UtilisateurService --> Organisme
EvaluationService --> Evaluation
EvaluationService --> Reponse
NotificationService --> Notification
NotificationService --> Utilisateur
DashboardService --> Evaluation
DashboardService --> Organisme
ReclamationService --> Reclamation
AuditLogService --> JournalAudit
DemandeCompteService --> DemandeCompte

@enduml
